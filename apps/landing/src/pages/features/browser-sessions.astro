---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import FeatureHero from "../../components/FeatureHero.astro";
import FeatureDetailGrid from "../../components/FeatureDetailGrid.astro";
import RelatedFeatures from "../../components/RelatedFeatures.astro";
import SeoHead from "../../components/SeoHead.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BottomCTA from "../../components/BottomCTA.astro";
import Footer from "../../components/Footer.astro";
import LiveBrowserSessions from "../../components/live/LiveBrowserSessions.astro";
import * as m from "../../paraglide/messages";

const pageTitle = m.page_bs_title();
const pageDescription = m.page_bs_desc();
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
    <SeoHead title={pageTitle} description={pageDescription} />
    <Nav />
    <Breadcrumb items={[{ label: m.breadcrumb_home(), href: "/" }, { label: m.breadcrumb_features(), href: "/#features" }, { label: m.page_bs_label() }]} />
    <FeatureHero
        label={m.page_bs_label()}
        title={m.page_bs_heading()}
        subtitle={m.page_bs_subtitle()}
    />

    <!-- Demo Mock: Session Replay -->
    <section class="py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
            <LiveBrowserSessions />
        </div>
    </section>

    <!-- Detail Grid -->
    <section class="py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6">
            <FeatureDetailGrid items={[
                { title: m.page_bs_timeline(), description: m.page_bs_timeline_desc() },
                { title: m.page_bs_replay(), description: m.page_bs_replay_desc() },
                { title: m.page_bs_correlation(), description: m.page_bs_correlation_desc() },
                { title: m.page_bs_capture(), description: m.page_bs_capture_desc() },
                { title: m.page_bs_errors(), description: m.page_bs_errors_desc() },
                { title: m.page_bs_privacy(), description: m.page_bs_privacy_desc() },
            ]} />
        </div>
    </section>

    <RelatedFeatures current="browser-sessions" />
    <BottomCTA />
    <Footer />
</Layout>
