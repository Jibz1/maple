---
/**
 * LiveBrowserSessions — session-replay artifact in the shared `.live-frame`
 * language (see LiveTrace / LiveLogStream). Two panes:
 *
 *   Left  — replay viewport: a wireframe of the recorded app with an animated
 *           cursor that travels to the "Pay now" button and clicks (ripple),
 *           plus a timeline scrubber that fills 0→100% on a loop with page
 *           tick marks and an mm:ss playhead clock.
 *   Right — session events: the distilled semantic stream (nav / click / input
 *           / console / net / error). Each row carries the trace id it occurred
 *           under — the trace↔replay correlation that's unique to Maple. The row
 *           at the current playhead position lights up in sequence with the scrub.
 *
 * Pure CSS animation (no JS island). Reduced motion freezes everything at the
 * click moment via the scoped media query at the bottom.
 */

type EventType = "nav" | "click" | "input" | "console" | "net" | "error";

interface SessionEvent {
	t: string;
	type: EventType;
	label: string;
	tid: string;
	bad?: boolean;
}

const events: SessionEvent[] = [
	{ t: "0:00", type: "nav", label: "/ — landing", tid: "1a2f" },
	{ t: "0:07", type: "click", label: "Pricing → /pricing", tid: "1a2f" },
	{ t: "0:21", type: "nav", label: "/checkout", tid: "9f3c" },
	{ t: "0:34", type: "input", label: "card number · masked", tid: "9f3c" },
	{ t: "0:48", type: "click", label: "Pay now", tid: "9f3c" },
	{ t: "0:49", type: "net", label: "POST /api/pay · 500", tid: "9f3c", bad: true },
	{ t: "0:49", type: "console", label: "PaymentError: declined", tid: "9f3c" },
	{ t: "0:50", type: "error", label: "Unhandled rejection", tid: "9f3c", bad: true },
	{ t: "1:12", type: "click", label: "Retry payment", tid: "b740" },
];

const typeLabel: Record<EventType, string> = {
	nav: "NAV",
	click: "CLICK",
	input: "INPUT",
	console: "CONSOLE",
	net: "NET",
	error: "ERROR",
};

const n = events.length;

// The backend trace behind the failed "Pay now" click — the full span
// timeline you land on from the replay. Positions are % of the 1.24s wall.
interface Span {
	svc: string;
	left: number;
	w: number;
	dur: string;
	depth: number;
	color: string;
	bad?: boolean;
}

const spans: Span[] = [
	{ svc: "edge", left: 0, w: 100, dur: "1.24s", depth: 0, color: "var(--service-1)" },
	{ svc: "api", left: 4.8, w: 14.5, dur: "180ms", depth: 1, color: "var(--service-2)" },
	{ svc: "payment-svc", left: 24, w: 71, dur: "880ms", depth: 1, color: "var(--severity-error)", bad: true },
	{ svc: "stripe", left: 34.7, w: 55.6, dur: "690ms", depth: 2, color: "var(--service-4)" },
	{ svc: "postgres", left: 91.9, w: 6.9, dur: "85ms", depth: 1, color: "var(--service-5)" },
];
---

<div class="grid lg:grid-cols-[1fr_300px] gap-4 bs-replay">
	<!-- Replay viewport -->
	<div class="live-frame">
		<div class="live-frame__head">
			<span>replay · checkout flow</span>
			<span class="live-frame__live">
				<span class="live-frame__live-dot"></span>
				LIVE
			</span>
		</div>

		<!-- Recorded URL + device chips -->
		<div class="bs-urlbar">
			<span class="bs-urlbar__dots" aria-hidden="true">
				<span></span><span></span><span></span>
			</span>
			<span class="bs-urlbar__url">app.acme.com/checkout</span>
			<span class="bs-chip">Chrome</span>
			<span class="bs-chip">macOS</span>
			<span class="bs-chip bs-chip--muted">Desktop</span>
		</div>

		<!-- The recorded screen (wireframe) -->
		<div class="bs-screen" aria-hidden="true">
			<!-- top bar -->
			<div class="bs-screen__topbar">
				<span class="bs-block bs-block--logo"></span>
				<span class="bs-block bs-line" style="width:48px"></span>
				<span class="bs-block bs-line" style="width:36px"></span>
				<span class="bs-block bs-line" style="width:42px"></span>
			</div>
			<!-- hero -->
			<div class="bs-block bs-screen__hero"></div>
			<!-- card row -->
			<div class="bs-screen__cards">
				<span class="bs-block bs-card"></span>
				<span class="bs-block bs-card"></span>
				<span class="bs-block bs-card"></span>
			</div>
			<!-- summary + pay button -->
			<div class="bs-screen__pay">
				<span class="bs-block bs-line" style="width:140px"></span>
				<span class="bs-paybtn">Pay now</span>
				<span class="bs-click-ripple"></span>
			</div>

			<!-- cursor -->
			<svg class="bs-cursor" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true">
				<path
					d="M1 1 L1 12 L4 9 L6.5 14.5 L8.5 13.6 L6 8 L10 8 Z"
					fill="var(--foreground)"
					stroke="var(--bg-deep)"
					stroke-width="1"
					stroke-linejoin="round"
				></path>
			</svg>
		</div>

		<!-- the correlated backend trace you land on from this moment -->
		<div class="bs-trace">
			<div class="bs-trace__head">
				<span>trace <span class="bs-trace__id">↳ 9f3c</span> · POST /api/pay</span>
				<span class="bs-trace__meta">1.24s · {spans.length} spans</span>
			</div>
			<div class="bs-trace__body">
				<span class="bs-trace-cursor" aria-hidden="true"></span>
				{
					spans.map((s) => (
						<div class="bs-trace-row" data-bad={s.bad ? "true" : undefined}>
							<span class="bs-trace-svc" style={`padding-left:${s.depth * 9}px`}>
								{s.svc}
							</span>
							<span class="bs-trace-track">
								<span class="bs-trace-bar" style={`left:${s.left}%; width:${s.w}%; --c:${s.color}`} />
							</span>
							<span class="bs-trace-dur">{s.dur}</span>
						</div>
					))
				}
			</div>
		</div>

		<div
			class="px-3.5 py-2.5 border-t border-border bg-bg-elevated text-[10px] uppercase tracking-wider text-fg-muted flex justify-between"
		>
			<span>1 session · {n} events · 2 errors</span>
			<span>trace-linked · 30d retention</span>
		</div>
	</div>

	<!-- Session events -->
	<aside class="live-frame">
		<div class="live-frame__head">
			<span>session events</span>
			<span class="text-fg-muted normal-case tracking-normal">{n} captured</span>
		</div>
		<div class="bs-events">
			{
				events.map((e, i) => (
					<div
						class="bs-event"
						data-type={e.type}
						data-bad={e.bad ? "true" : undefined}
						style={`--i:${i}; --n:${n}`}
					>
						<span class="bs-event__t">{e.t}</span>
						<span class="bs-event__chip">{typeLabel[e.type]}</span>
						<span class="bs-event__label">{e.label}</span>
						<span class="bs-event__tid">↳ {e.tid}</span>
					</div>
				))
			}
		</div>
		<div
			class="px-3.5 py-2.5 border-t border-border bg-bg-elevated text-[10px] uppercase tracking-wider text-fg-muted flex justify-between"
		>
			<span>jump to trace</span>
			<span>9f3c · 1.24s</span>
		</div>
	</aside>
</div>

<style>
	/* ── Recorded URL bar ─────────────────────────────────────────── */
	.bs-urlbar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
		background: color-mix(in oklab, var(--bg-elevated) 70%, transparent);
	}
	.bs-urlbar__dots {
		display: inline-flex;
		gap: 4px;
	}
	.bs-urlbar__dots span {
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: color-mix(in oklab, var(--border) 90%, transparent);
	}
	.bs-urlbar__url {
		flex: 1;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted-foreground);
		background: var(--bg-deep);
		border: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
		border-radius: 6px;
		padding: 3px 10px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.bs-chip {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--foreground);
		border: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
		border-radius: 999px;
		padding: 2px 7px;
		white-space: nowrap;
	}
	.bs-chip--muted {
		color: var(--muted-foreground);
	}

	/* ── Recorded screen (wireframe) ──────────────────────────────── */
	.bs-screen {
		position: relative;
		height: 256px;
		padding: 14px;
		overflow: hidden;
		background:
			radial-gradient(
				ellipse 120% 80% at 50% -10%,
				color-mix(in oklab, var(--primary) 6%, transparent),
				transparent 60%
			),
			var(--bg-deep);
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.bs-block {
		display: block;
		background: color-mix(in oklab, var(--bg-elevated) 80%, var(--foreground) 4%);
		border-radius: 4px;
	}
	.bs-line {
		height: 8px;
	}
	.bs-screen__topbar {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.bs-block--logo {
		width: 22px;
		height: 22px;
		border-radius: 6px;
		background: color-mix(in oklab, var(--primary) 30%, var(--bg-elevated));
	}
	.bs-screen__topbar .bs-line {
		margin-left: auto;
	}
	.bs-screen__topbar .bs-line:not(:last-child) {
		margin-left: 0;
	}
	.bs-screen__hero {
		height: 64px;
		background:
			linear-gradient(
				100deg,
				color-mix(in oklab, var(--bg-elevated) 90%, transparent),
				color-mix(in oklab, var(--bg-elevated) 60%, transparent)
			);
	}
	.bs-screen__cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
	}
	.bs-card {
		height: 52px;
	}
	.bs-screen__pay {
		position: relative;
		display: flex;
		align-items: center;
		gap: 14px;
		margin-top: auto;
	}
	.bs-paybtn {
		margin-left: auto;
		font-family: var(--font-display);
		font-size: 12px;
		font-weight: 600;
		color: var(--primary-foreground);
		background: var(--primary);
		border-radius: 8px;
		padding: 8px 18px;
	}
	.bs-click-ripple {
		position: absolute;
		right: 38px;
		bottom: 14px;
		width: 12px;
		height: 12px;
		border-radius: 999px;
		border: 1.5px solid var(--primary);
		opacity: 0;
		transform: scale(0.3);
		animation: bs-click 14s ease-out infinite;
		pointer-events: none;
	}

	/* ── Cursor ──────────────────────────────────────────────────── */
	.bs-cursor {
		position: absolute;
		left: 18%;
		top: 22%;
		filter: drop-shadow(0 1px 2px oklch(0 0 0 / 50%));
		animation: bs-cursor 14s cubic-bezier(0.5, 0, 0.5, 1) infinite;
		will-change: left, top, transform;
	}

	@keyframes bs-cursor {
		0% { left: 18%; top: 20%; transform: scale(1); }
		14% { left: 70%; top: 16%; transform: scale(1); }
		28% { left: 32%; top: 48%; transform: scale(1); }
		44% { left: 82%; top: 82%; transform: scale(1); }
		49% { left: 84%; top: 84%; transform: scale(0.82); }
		52% { left: 84%; top: 84%; transform: scale(1); }
		72% { left: 56%; top: 56%; transform: scale(1); }
		100% { left: 18%; top: 20%; transform: scale(1); }
	}

	@keyframes bs-click {
		0%, 46% { opacity: 0; transform: scale(0.3); }
		49% { opacity: 0.9; transform: scale(0.6); }
		56% { opacity: 0; transform: scale(2.4); }
		100% { opacity: 0; transform: scale(2.4); }
	}

	/* ── Correlated trace timeline ───────────────────────────────── */
	.bs-trace {
		padding: 11px 14px 13px;
		border-top: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
		background: color-mix(in oklab, var(--bg-elevated) 35%, transparent);
	}
	.bs-trace__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 9px;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--muted-foreground);
	}
	.bs-trace__id {
		color: var(--primary);
	}
	.bs-trace__meta {
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}
	.bs-trace__body {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.bs-trace-row {
		display: grid;
		grid-template-columns: 88px 1fr 50px;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 10px;
	}
	.bs-trace-svc {
		color: var(--foreground);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.bs-trace-track {
		position: relative;
		height: 9px;
		border-radius: 3px;
		background: color-mix(in oklab, var(--bg-elevated) 85%, transparent);
	}
	.bs-trace-bar {
		position: absolute;
		top: 0;
		bottom: 0;
		border-radius: 3px;
		background: var(--c, var(--primary));
	}
	.bs-trace-dur {
		color: var(--muted-foreground);
		text-align: right;
		font-variant-numeric: tabular-nums;
	}
	.bs-trace-row[data-bad] .bs-trace-svc {
		color: var(--severity-error);
	}
	.bs-trace-row[data-bad] .bs-trace-bar {
		box-shadow: 0 0 0 1px color-mix(in oklab, var(--severity-error) 60%, transparent);
	}
	/* playhead sweeping the trace — the same moment, on the backend */
	.bs-trace-cursor {
		position: absolute;
		top: -3px;
		bottom: -3px;
		left: 96px;
		width: 1px;
		background: color-mix(in oklab, var(--primary) 70%, transparent);
		animation: bs-trace-sweep 14s linear infinite;
		will-change: left;
		pointer-events: none;
	}
	.bs-trace-cursor::before {
		content: "";
		position: absolute;
		top: -1px;
		left: -2px;
		width: 5px;
		height: 5px;
		border-radius: 999px;
		background: var(--primary);
	}
	/* sweep across the bar-track region (between the 88px label col and 50px dur col) */
	@keyframes bs-trace-sweep {
		0% { left: 96px; }
		100% { left: calc(100% - 58px); }
	}

	/* ── Session events ──────────────────────────────────────────── */
	.bs-events {
		padding: 4px 0;
		max-height: 322px;
		overflow: hidden;
	}
	.bs-event {
		display: grid;
		grid-template-columns: 6ch 7ch 1fr;
		grid-template-areas: "t chip label" ". chip tid";
		align-items: center;
		column-gap: 8px;
		row-gap: 1px;
		padding: 5px 14px;
		font-size: 11px;
		font-family: var(--font-mono);
		border-bottom: 1px solid color-mix(in oklab, var(--border) 35%, transparent);
		border-left: 2px solid transparent;
		animation: bs-event-pass 14s linear infinite;
		animation-delay: calc(var(--i) / var(--n) * 14s);
		will-change: background, border-color;
	}
	.bs-event:last-child {
		border-bottom: none;
	}
	.bs-event__t {
		grid-area: t;
		color: var(--muted-foreground);
		font-variant-numeric: tabular-nums;
	}
	.bs-event__chip {
		grid-area: chip;
		justify-self: start;
		font-size: 8px;
		font-weight: 600;
		letter-spacing: 0.06em;
		padding: 1px 5px;
		border-radius: 4px;
		border: 1px solid currentColor;
		opacity: 0.9;
	}
	.bs-event__label {
		grid-area: label;
		color: var(--foreground);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.bs-event__tid {
		grid-area: tid;
		color: color-mix(in oklab, var(--muted-foreground) 80%, transparent);
		font-size: 9.5px;
	}

	/* chip colours by type */
	.bs-event[data-type="nav"] .bs-event__chip { color: var(--severity-info); }
	.bs-event[data-type="click"] .bs-event__chip { color: var(--primary); }
	.bs-event[data-type="input"] .bs-event__chip { color: var(--muted-foreground); }
	.bs-event[data-type="console"] .bs-event__chip { color: var(--severity-warn); }
	.bs-event[data-type="net"] .bs-event__chip { color: var(--severity-debug); }
	.bs-event[data-type="net"][data-bad] .bs-event__chip { color: var(--severity-error); }
	.bs-event[data-type="error"] .bs-event__chip { color: var(--severity-error); }
	.bs-event[data-bad] .bs-event__label { color: var(--severity-error); }

	/* playhead sweep highlight — each row lights as the scrubber passes it */
	@keyframes bs-event-pass {
		0% {
			background: transparent;
			border-left-color: transparent;
		}
		2% {
			background: color-mix(in oklab, var(--primary) 9%, transparent);
			border-left-color: var(--primary);
		}
		9% {
			background: color-mix(in oklab, var(--primary) 9%, transparent);
			border-left-color: var(--primary);
		}
		16%, 100% {
			background: transparent;
			border-left-color: transparent;
		}
	}

	/* ── Reduced motion — freeze at the click moment ─────────────── */
	@media (prefers-reduced-motion: reduce) {
		.bs-cursor {
			animation: none;
			left: 84%;
			top: 84%;
		}
		.bs-click-ripple {
			animation: none;
			opacity: 0.6;
			transform: scale(1);
		}
		.bs-trace-cursor {
			animation: none;
			left: 50%;
		}
		.bs-event {
			animation: none;
		}
		/* surface the "Pay now" click row as the active one */
		.bs-event[data-type="click"]:nth-of-type(5) {
			background: color-mix(in oklab, var(--primary) 9%, transparent);
			border-left-color: var(--primary);
		}
	}
</style>
